{
  "root": true,
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "extends": ["eslint:recommended"],
  "ignorePatterns": ["node_modules/", ".next/", "dist/", "build/"],
  "rules": {
    "no-console": "warn"
  }
}
